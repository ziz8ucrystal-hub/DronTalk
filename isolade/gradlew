##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell such as ksh or
#       bash, then to run this script, type that shell name before the whole
#       command line, like:
#
#           ksh gradle
#
#       Busybox and similar reduced shells will NOT work, because this script
#       requires all of these POSIX shell features:
#         * functions;
#         * expansions «$var», «${var}», «${var:-default}», «${var+set}», «${var#pattern}», «${var%pattern}», and «$( cmd )»;
#         * compound commands having a testable exit status, especially «case»;
#         * various built-in commands including «command», «set», and «ulimit».
#
#   Important for patching:
#
#   (2) This script targets any POSIX shell, so it avoids extensions provided
#       by other shells (bash, ksh, etc); in particular arrays are avoided.
#
#       The "traditional" practice of packing multiple parameters into a
#       space-separated string is a well documented source of bugs and security
#       problems, so this is (mostly) avoided, by progressively accumulating
#       options in "$@", and eventually passing that to Java.
#
#       Where the inherited environment variables (DEFAULT_JVM_OPTS, JAVA_OPTS,
#       and GRADLE_OPTS) rely on word-splitting, this is performed explicitly;
#       see the in-line comments for details.
#
#       There are tweaks for specific operating systems such as AIX, CygWin,
#       Darwin, MinGW, and NonStop.
#
#   (3) This script is generated from the Groovy template
#       https://github.com/gradle/gradle/blob/HEAD/subprojects/plugins/src/main/resources/org/gradle/api/internal/plugins/unixStartScript.txt
#       within the Gradle project.
#
#       You can find Gradle at https://github.com/gradle/gradle/.
#
##############################################################################

# Attempt to set APP_HOME

# Resolve links: $0 may be a link
app_path=$0

# Need this for daisy-chained symlinks.
while
    APP_HOME=${app_path%"${app_path##*/}"}  # leaves a trailing /; empty if no leading path
    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=${ls#*' -> '}
    case $link in             #(
      /*)   app_path=$link ;; #(
      *)    app_path=$APP_HOME$link ;;
    esac
done

# This is normally unused
# shellcheck disable=SC2034
APP_BASE_NAME=${app_path##*/}
# Discard cd standard output in case $CDPATH is set https://github.com/gradle/gradle/issues/25036
APP_HOME=$( cd -P "${APP_HOME:-./}" > /dev/null && printf '%s
' "$PWD" ) || exit

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$( uname )" in                #(
  CYGWIN* )         cygwin=true  ;; #(
  Darwin* )         darwin=true  ;; #(
  MSYS* | MINGW* )  msys=true    ;; #(
  NONSTOP* )        nonstop=true ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar


# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD=java
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
fi

# Increase the maximum file descriptors if we can.
if ! "$cygwin" && ! "$darwin" && ! "$nonstop" ; then
    case $MAX_FD in #(
      max*)
        # In POSIX sh, ulimit -H is undefined. That's why the result is checked to see if it worked.
        # shellcheck disable=SC2039,SC3045
        MAX_FD=$( ulimit -H -n ) ||
            warn "Could not query maximum file descriptor limit"
    esac
    case $MAX_FD in  #(
      '' | soft) :;; #(
      *)
        # In POSIX sh, ulimit -n is undefined. That's why the result is checked to see if it worked.
        # shellcheck disable=SC2039,SC3045
        ulimit -n "$MAX_FD" ||
            warn "Could not set maximum file descriptor limit to $MAX_FD"
    esac
fi

# Collect all arguments for the java command, stacking in reverse order to eventually pass to java.
# We cannot use arrays for this, because POSIX sh does not support arrays.

# We use "set --" to build the args for the java command in the current shell.
# It puts all the arguments into the positional parameters (distinct from command line args, e.g., $1, $2...).

# Many of the segments in this function are split to preserve argument boundaries and avoid spaces-within-arguments problems.
# The segments are separated by newlines, and the surrounding vars are `set`-away to preserve them, but apparently
# some shells (like dash) do not handle that correctly.

# The "set --" line groups the segments into the positional parameters, as they were concatenated in the printed order.
# We have tried to make sure that works, but if you get to here and the output is wrong, please implement a more
# careful logic.

# We used to have `set -- $( ... )`, which worked in most shells, but would insert the arguments into the command line
# after a word-splitting step, which is exactly what we want to avoid. Now we write the arguments into a file and
# use `cat` to output them, so that we don't have to worry about word splitting, as the arguments will stay as-is.

# Prepend application arguments (e.g., `-Dsome.property=some.value` or `some"string with"space`) to the command line,
# but before any Gradle-specific arguments (like "-b" or "--project-dir").

# Put all Gradle-specific arguments at the very end, after application arguments.
# We try to put the app/p settings first, then the project cache, then whatever is left.

# Inlined why we had this complicated scheme - we want to support multiple arguments with spaces, like "help --info"
# and also "android:compileDebug". We can't use arrays in POSIX, but we can use the fact that arguments are concatenated
# when they are written to the file, and we can just output them without any shell processing.

# So here we accumulate the arguments into a file, and then we set the positional parameters to the contents of that file.

# This function takes the arguments, splits them into segments (see "Argument segments"), and writes them to a file.
# It reads them from the file and sets the positional parameters.

# The "argument segments" are:
#   * The default JVM options (DEFAULT_JVM_OPTS)
#   * The JAVA_OPTS and GRADLE_OPTS environment variables (if any)
#   * The command-line arguments

# We want to make sure that the application arguments come before any Gradle arguments.

# The algorithm is:
#   1. Concatenate all arguments into a string.
#   2. Write that string to a file, using null bytes as separators.
#   3. Read the file and set the positional parameters to its contents.

# We use null bytes as separators because arguments may contain spaces, and we want to preserve them.
# We read the file using `xargs -0` (if available) or a simple loop, which is less robust.

# Fallback to simple loop if xargs is not available.
if command -v xargs >/dev/null 2>&1; then
    # Use xargs to split the arguments.
    set -- $(
        printf '%s\n' "$DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS" |
        xargs -0 printf '%s\n' |
        cat - "$APP_HOME/unknown" |
        head -n -1
    )
else
    # Use a simple loop to split the arguments.
    # This is less robust, but it works in most cases.
    # We set IFS to newline to split on newlines, not spaces.
    IFS='
'
    set -- $(
        printf '%s\n' "$DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS" |
        while read -r line; do
            printf '%s\n' "$line"
        done |
        cat - "$APP_HOME/unknown" |
        head -n -1
    )
    unset IFS
fi

# Collect all arguments for the java command, stacking in reverse order to eventually pass to java.
# We cannot use arrays for this, because POSIX sh does not support arrays.

# The "set --" line groups the segments into the positional parameters, as they were concatenated in the printed order.
# We have tried to make sure that works, but if you get to here and the output is wrong, please implement a more
# careful logic.

# We used to have `set -- $( ... )`, which worked in most shells, but would insert the arguments into the command line
# after a word-splitting step, which is exactly what we want to avoid. Now we write the arguments into a file and
# use `cat` to output them, so that we don't have to worry about word splitting, as the arguments will stay as-is.

# Prepend application arguments (e.g., `-Dsome.property=some.value` or `some"string with"space`) to the command line,
# but before any Gradle-specific arguments (like "-b" or "--project-dir").

# Put all Gradle-specific arguments at the very end, after application arguments.
# We try to put the app/p settings first, then the project cache, then whatever is left.

# We are going to pass the arguments to java in a way that avoids word-splitting issues.
# We write the arguments to a file and then use `cat` to output them.

# Write the arguments to a temporary file.
tmpFile=$(mktemp)
trap 'rm -f "$tmpFile"' EXIT

# Write the arguments to the file, separated by null bytes.
# We use printf because echo may interpret backslashes.
printf '%s\0' "$@" > "$tmpFile"

# Read the arguments from the file and set the positional parameters.
if command -v xargs >/dev/null 2>&1; then
    # Use xargs to split the arguments.
    set -- $(xargs -0 < "$tmpFile")
else
    # Use a simple loop to split the arguments.
    # This is less robust, but it works in most cases.
    # We set IFS to null to split on null bytes.
    IFS=
    set -- $(cat "$tmpFile")
    unset IFS
fi

# Now we have the arguments in the positional parameters.
# We can now pass them to java.

# We try to separate the application arguments from the Gradle arguments.
# We don't know which are which, so we just pass them all.

# Finally, we execute java.
exec "$JAVACMD" "$@"
