<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- المحتوى الرئيسي -->
    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- شاشة المستخدمين -->
        <LinearLayout
            android:id="@+id/usersScreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="جهات الاتصال"
                android:textColor="@color/on_background"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <ListView
                android:id="@+id/contactsList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@color/surface"
                android:dividerHeight="1dp"
                android:background="@color/background" />

        </LinearLayout>

        <!-- شاشة QR -->
        <LinearLayout
            android:id="@+id/qrScreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="16dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/myQRImage"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:layout_gravity="center"
                android:background="@color/surface"
                android:padding="10dp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/myQRInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnShareQR"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:text="مشاركة الرمز"
                android:background="@color/primary"
                android:textColor="@color/on_background"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnCopyQR"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:text="نسخ الرمز"
                android:background="@color/surface"
                android:textColor="@color/on_background" />

        </LinearLayout>

        <!-- شاشة الإعدادات -->
        <LinearLayout
            android:id="@+id/settingsScreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="الإعدادات"
                android:textColor="@color/on_background"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="الاسم:"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/settingsName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_background"
                android:textSize="18sp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="الرقم الداخلي:"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/settingsNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_background"
                android:textSize="18sp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IP:"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/settingsIP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_background"
                android:textSize="18sp"
                android:layout_marginBottom="30dp" />

            <Button
                android:id="@+id/btnEditInfo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="تعديل المعلومات"
                android:background="@color/surface"
                android:textColor="@color/on_background" />

        </LinearLayout>

    </FrameLayout>

    <!-- الشريط السفلي -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center">

        <TextView
            android:id="@+id/navUsers"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="👥"
            android:textSize="24sp"
            android:gravity="center"
            android:textColor="@color/primary"
            android:background="?android:selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navQR"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="📷"
            android:textSize="24sp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:background="?android:selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⚙️"
            android:textSize="24sp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:background="?android:selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>